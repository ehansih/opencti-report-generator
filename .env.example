# ─── OpenCTI ─────────────────────────────────────────────────────────────────
OPENCTI_URL=http://localhost:8080
OPENCTI_TOKEN=your-opencti-api-token-here

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── SSL (Zscaler / corporate proxy) ─────────────────────────────────────────
# Path to combined CA bundle (Zscaler + system CAs)
# Leave blank to use default system certificates
SSL_CERT_PATH=

# ─── Report Output ───────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ─── Web Dashboard ───────────────────────────────────────────────────────────
PORT=5050
